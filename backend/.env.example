# LLM
ANTHROPIC_API_KEY=your_anthropic_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embeddings
VOYAGE_API_KEY=your_voyage_key_here
EMBEDDING_MODEL=voyage-3

# Database
DATABASE_URL=postgresql://agentcoach:agentcoach@localhost:5432/agentcoach

# App
ENV=development

# CORS — comma-separated production frontend origins (localhost is always allowed).
# e.g. your Vercel URL. Leave default unless your domain changes.
CORS_ORIGINS=https://agent-coach-topaz.vercel.app
# Allow any https://<name>.vercel.app origin (Vercel preview deployments).
CORS_ALLOW_VERCEL=true
